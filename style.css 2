body{
  font-family: Arial, sans-serif;
  margin:0;
  background:#f5f5f5;
}
header{
  background:#6c4cff;
  color:white;
  padding:15px;
  display:flex;
  justify-content:space-between;
}
header input{
  padding:8px;
  border:none;
  border-radius:5px;
}
.container{
  display:flex;
  flex-wrap:wrap;
}
.sidebar{
  width:200px;
  background:white;
  padding:20px;
}
.sidebar ul{
  list-style:none;
  padding:0;
}
.sidebar li{
  padding:8px 0;
  cursor:pointer;
}
.sidebar li.active{
  font-weight:bold;
  color:#6c4cff;
}
.products{
  flex:1;
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:20px;
  padding:20px;
}
.product{
  background:white;
  padding:15px;
  border-radius:10px;
  text-align:center;
}
.product img{
  width:100%;
  border-radius:10px;
}
.product button{
  background:#6c4cff;
  color:white;
  border:none;
  padding:10px;
  margin-top:10px;
  border-radius:5px;
  cursor:pointer;
}
footer{
  text-align:center;
  padding:15px;
  background:white;
}
@media(max-width:768px){
  .container{
    flex-direction:column;
  }
  .sidebar{
    width:100%;
    display:flex;
    overflow-x:auto;
  }
  .sidebar ul{
    display:flex;
    gap:15px;
  }
  .products{
    grid-template-columns:repeat(auto-fill,minmax(150px,1fr));
  }
}
